# --- Broker (red interna de docker compose) ---
KAFKA_BROKERS=broker:9092

# --- Postgres ---
DATABASE_URL=postgresql://mordisbot:mordisbot@db:5432/mordisbot

# --- Parametros de la regla CEP "Tendencia detectada" (escalados para demo) ---
# Regla real (Actividad 1): >= 50 busquedas de cocina X en zona Y en 72hs
# Regla de demo: >= TREND_THRESHOLD busquedas en TREND_WINDOW_SECONDS
TREND_WINDOW_SECONDS=60
TREND_THRESHOLD=5

# --- b2b-dashboard ---
DASHBOARD_PORT=3000
